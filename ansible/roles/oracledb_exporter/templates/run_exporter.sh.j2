#!/bin/bash

source /etc/profile.d/oracle_exporter.sh

LOG_FILE="{{ exporter_log_dir }}/exporter.log"
LISTEN_ADDRESS="{{ exporter_listen_address }}"
PID_FILE="{{ exporter_pid_file }}"
BINARY="{{ exporter_bin_dir }}/oracledb_exporter"

echo "Starting oracledb_exporter v{{ oracle_exporter_version }} at $(date)" | tee -a "$LOG_FILE"
echo "DB_CONNECT_STRING=${DB_CONNECT_STRING}" | tee -a "$LOG_FILE"

nohup $BINARY \
    --default.metrics {{ exporter_config_dir }}/default-metrics.toml \
    --log.level error \
    --web.listen-address "$LISTEN_ADDRESS" \
    >> "$LOG_FILE" 2>&1 &

EXPORTER_PID=$!
echo $EXPORTER_PID > "$PID_FILE"
echo "PID: $EXPORTER_PID" | tee -a "$LOG_FILE"

sleep 2
if kill -0 $EXPORTER_PID 2>/dev/null; then
    echo "Exporter started successfully" | tee -a "$LOG_FILE"
else
    echo "Exporter failed to start" | tee -a "$LOG_FILE"
    tail -20 "$LOG_FILE"
    exit 1
fi

cleanup() {
    echo "Stopping exporter (PID: $EXPORTER_PID)..." | tee -a "$LOG_FILE"
    kill $EXPORTER_PID 2>/dev/null
    wait $EXPORTER_PID
    rm -f "$PID_FILE"
}
trap cleanup SIGTERM SIGINT

wait $EXPORTER_PID
